{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleDetection": "force",
    "moduleResolution": "node",
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["ES2021", "DOM"],
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "useUnknownInCatchVariables": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
